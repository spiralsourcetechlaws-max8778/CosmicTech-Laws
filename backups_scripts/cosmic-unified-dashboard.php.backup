            ⚡ System Check
        </button>
        <button class="action-btn" onclick="window.location.href='quick.php'">
            🚀 Quick Nav
        </button>
    </div>
    
    <h2 style="margin: 30px 0 15px 0; color: var(--cosmic-purple); border-bottom: 1px solid var(--cosmic-blue); padding-bottom: 10px;">
        🛠️ Integrated Modules
    </h2>
    
    <div class="modules-grid">
        <?php foreach ($modules as $key => $module): ?>
        <a href="<?php echo $module['endpoints']['generate'] ?? '#'; ?>" 
           class="module-link" 
           onclick="return <?php echo $module['status'] === 'active' ? 'true' : 'alert(\'Module inactive\'); false'; ?>">
            <div class="module-card <?php echo $module['status']; ?>">
                <div class="module-icon"><?php echo $module['icon']; ?></div>
                <h3><?php echo $module['name']; ?></h3>
                <p style="color: #ccc; font-size: 0.9em; margin: 10px 0;">
                    <?php echo $module['description']; ?>
                </p>
                <div style="display: flex; justify-content: space-between; margin-top: 15px;">
                    <span style="color: #888; font-size: 0.8em;">
                        v<?php echo $module['version']; ?>
                    </span>
                    <span class="module-status status-<?php echo $module['status']; ?>">
                        <?php echo strtoupper($module['status']); ?>
                    </span>
                </div>
            </div>
        </a>
        <?php endforeach; ?>
    </div>
    
    <div class="terminal-output" id="systemLog">
        <div class="log-entry">
            <span style="color: #888;">[<?php echo date('H:i:s'); ?>]</span>
            <span style="color: var(--cosmic-green);"> System initialized</span>
        </div>
        <div class="log-entry">
            <span style="color: #888;">[<?php echo date('H:i:s'); ?>]</span>
            <span style="color: var(--cosmic-blue);"> Loaded <?php echo count($modules); ?> modules</span>
        </div>
        <div class="log-entry">
            <span style="color: #888;">[<?php echo date('H:i:s'); ?>]</span>
            <span style="color: var(--cosmic-green);"> Ready for security operations</span>
        </div>
    </div>
    
    <script>
        // Auto-update log
        function addLog(message, type = 'info') {
            const colors = {
                'info': '#00ff00',
                'warning': '#ffff00',
                'error': '#ff0000',
                'debug': '#00ffff'
            };
            
            const log = document.getElementById('systemLog');
            const entry = document.createElement('div');
            entry.className = 'log-entry';
            entry.innerHTML = `
                <span style="color: #888;">[${new Date().toLocaleTimeString()}]</span>
                <span style="color: ${colors[type]};"> ${message}</span>
            `;
            log.appendChild(entry);
            log.scrollTop = log.scrollHeight;
        }
        
        // System diagnostic
        function runSystemDiagnostic() {
            addLog('Running system diagnostic...', 'info');
            
            // Simulate checks
            setTimeout(() => addLog('✓ Trojan module: OK', 'info'), 500);
            setTimeout(() => addLog('✓ Red Team module: OK', 'info'), 1000);
            setTimeout(() => addLog('✓ AI module: OK', 'info'), 1500);
            setTimeout(() => addLog('✓ Lab environment: OK', 'info'), 2000);
            setTimeout(() => addLog('✓ All systems operational', 'debug'), 2500);
        }
        
        // Module interaction
        document.querySelectorAll('.module-card').forEach(card => {
            card.addEventListener('click', function(e) {
                if (this.classList.contains('active')) {
                    this.style.transform = 'scale(0.98)';
                    setTimeout(() => {
                        this.style.transform = '';
                    }, 200);
                }
            });
        });
        
        // Add heartbeat
        setInterval(() => {
            const now = new Date();
            if (now.getSeconds() === 0) {
                addLog('Heartbeat: System normal', 'debug');
            }
        }, 1000);
        
        // Initialize
        console.log('COSMIC OSINT LAB Unified Dashboard loaded');
    </script>
</body>
</html>
