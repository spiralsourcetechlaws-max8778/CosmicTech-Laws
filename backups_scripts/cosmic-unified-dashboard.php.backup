<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌀 COSMIC OSINT LAB - Unified Dashboard</title>
    <style>
        :root {
            --cosmic-purple: #8a2be2;
            --cosmic-blue: #00ffff;
            --cosmic-green: #00ff00;
            --cosmic-red: #ff0000;
            --cosmic-yellow: #ffff00;
            --cosmic-bg: #0a0a0a;
            --cosmic-card: rgba(20, 20, 40, 0.9);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Courier New', monospace;
            background: var(--cosmic-bg);
            color: var(--cosmic-green);
            background-image: 
                radial-gradient(circle at 20% 30%, rgba(138, 43, 226, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(0, 255, 255, 0.1) 0%, transparent 50%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .terminal-header {
            background: rgba(10, 10, 30, 0.9);
            border: 2px solid var(--cosmic-purple);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 30px;
            position: relative;
            overflow: hidden;
        }
        
        .header-scanline {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--cosmic-blue), transparent);
            animation: scan 3s linear infinite;
        }
        
        @keyframes scan {
            0% { transform: translateY(0); }
            100% { transform: translateY(100vh); }
        }
        
        .system-status {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }
        
        .status-card {
            background: var(--cosmic-card);
            border: 1px solid var(--cosmic-blue);
            border-radius: 8px;
            padding: 15px;
            transition: all 0.3s;
        }
        
        .status-card:hover {
            transform: translateY(-5px);
            border-color: var(--cosmic-purple);
            box-shadow: 0 5px 20px rgba(138, 43, 226, 0.3);
        }
        
        .modules-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }
        
        .module-card {
            background: var(--cosmic-card);
            border: 2px solid;
            border-radius: 10px;
            padding: 20px;
            transition: all 0.3s;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }
        
        .module-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
            transform: rotate(45deg);
            transition: all 0.5s;
        }
        
        .module-card:hover::before {
            left: 100%;
        }
        
        .module-card.active {
            border-color: var(--cosmic-green);
        }
        
        .module-card.inactive {
            border-color: var(--cosmic-red);
            opacity: 0.7;
        }
        
        .module-card.developing {
            border-color: var(--cosmic-yellow);
        }
        
        .module-icon {
            font-size: 40px;
            margin-bottom: 10px;
        }
        
        .module-status {
            position: absolute;
            top: 10px;
            right: 10px;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
        }
        
        .status-active {
            background: rgba(0, 255, 0, 0.2);
            color: var(--cosmic-green);
        }
        
        .status-inactive {
            background: rgba(255, 0, 0, 0.2);
            color: var(--cosmic-red);
        }
        
        .status-developing {
            background: rgba(255, 255, 0, 0.2);
            color: var(--cosmic-yellow);
        }
        
        .quick-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
            margin: 20px 0;
        }
        
        .action-btn {
            background: rgba(20, 20, 40, 0.8);
            border: 1px solid var(--cosmic-blue);
            color: var(--cosmic-blue);
            padding: 10px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s;
            text-align: center;
        }
        
        .action-btn:hover {
            background: var(--cosmic-blue);
            color: #000;
            transform: scale(1.05);
        }
        
        .terminal-output {
            background: rgba(0, 0, 0, 0.8);
            border: 1px solid var(--cosmic-green);
            border-radius: 8px;
            padding: 15px;
            margin-top: 20px;
            font-family: monospace;
            font-size: 12px;
            max-height: 200px;
            overflow-y: auto;
        }
        
        .log-entry {
            padding: 5px 0;
            border-bottom: 1px solid rgba(0, 255, 0, 0.1);
        }
        
        .module-link {
            text-decoration: none;
            color: inherit;
            display: block;
        }
        
        @media (max-width: 768px) {
            .modules-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="terminal-header">
        <div class="header-scanline"></div>
        <h1 style="color: var(--cosmic-purple); text-align: center; font-size: 2.5em;">
            🌀 COSMIC OSINT LAB
        </h1>
        <p style="text-align: center; color: var(--cosmic-blue); margin: 10px 0;">
            Unified Security Operations Platform
        </p>
        <p style="text-align: center; color: #888; font-size: 0.9em;">
            Version 2.0 | All systems integrated
        </p>
    </div>
    
