            <div style="font-size: 1.2em; font-weight: bold; margin-top: 5px;">
                <?php echo htmlspecialchars($value); ?>
            </div>
        </div>
        <?php endforeach; ?>
    </div>
    
    <div class="quick-actions">
        <button class="action-btn" onclick="window.location.href='trojan-dashboard.php'">
            🏴‍☠️ Generate Payload
        </button>
        <button class="action-btn" onclick="window.location.href='redteam-dashboard.php'">
